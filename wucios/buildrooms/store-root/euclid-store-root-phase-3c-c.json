{
  "schema": "wucios.euclid.phase3c_c.plan.v1",
  "phase_id": "euclid-trial-phase-3c-c",
  "phase_name": "WuciOS v2.4 Euclid Trial Phase 3C-C — NixOS/Guix Store-Root Preparation",
  "status": "CANDIDATE_TRIAL_PHASE",
  "default_execution_mode": "L1_STORE_ROOT_POLICY_AND_DECLARATIVE_INPUTS",
  "l1_authorized_by_default": true,
  "l2_scaffold_authorized_by_default": false,
  "l2_scaffold_authorization_env": "WUCIOS_PHASE3CC_ALLOW_L2_SCAFFOLD=1",
  "l3_substrate_artifact_attempts_allowed": false,
  "runtime_inspection_allowed": false,
  "store_realization_allowed": false,
  "derivation_build_allowed": false,
  "package_build_allowed": false,
  "system_activation_allowed": false,
  "rootfs_generation_allowed": false,
  "substrate_selection": "NO_SUBSTRATE_SELECTED",
  "ranking_allowed": false,
  "emotional_testing_allowed": false,
  "numeric_score_allowed": false,
  "network_default": "DISABLED",
  "image_pulls_allowed": false,
  "container_builds_allowed": false,
  "container_runs_allowed": false,
  "vm_runs_allowed": false,
  "sudo_allowed": false,
  "host_package_install_allowed": false,
  "source_clone_allowed": false,
  "os_image_download_allowed": false,
  "in_scope_candidates": [
    "nixos_store_root",
    "guix_store_root"
  ],
  "out_of_scope_preserved": {
    "phase_3c_b_direct_rootfs": [
      "buildroot",
      "alpine",
      "debian-minimal",
      "void"
    ],
    "phase_3c_d_heavy_source": [
      "yocto"
    ],
    "phase_3c_e_reference_runtime": [
      "openbsd-reference"
    ]
  },
  "direct_rootfs_assumptions_insufficient_because": [
    "store-rooted systems require store identity policy before artifact attempts",
    "declarative system inputs must be pinned and reviewed before evaluation or realization",
    "channel or flake identity is part of the evidence boundary",
    "system activation is a separate L4 boundary and is not authorized"
  ],
  "allowed_l1_actions": [
    "static policy recognition",
    "schema validation",
    "candidate status reporting",
    "missing declarative input detection",
    "declarative-input manifest checks",
    "ignored report generation"
  ],
  "allowed_l2_actions": [
    "generate non-artifact scaffold files under build/wucios",
    "generate declarative-input placeholder manifests",
    "generate future command manifests as non-executable policy artifacts",
    "generate placeholder evidence manifests",
    "do not execute scaffold files",
    "do not evaluate, build, realize, or activate store inputs"
  ],
  "forbidden_actions": [
    "nix-build",
    "nixos-rebuild",
    "nix develop",
    "nix shell",
    "nix flake check",
    "guix build",
    "guix system",
    "guix shell",
    "guix environment",
    "guix pull",
    "store realization",
    "derivation build",
    "package build",
    "system activation",
    "network fetch",
    "OS image download",
    "rootfs generation",
    "image action",
    "container action",
    "VM launch",
    "sudo",
    "package installation",
    "source clone",
    "substrate selection",
    "candidate ranking",
    "numeric WuciOS score"
  ],
  "objectives": [
    "Define controlled store-root preparation rules for NixOS and Guix.",
    "Separate declarative-input preparation from direct-rootfs assumptions.",
    "Define future L3 evidence requirements without executing them.",
    "Generate optional non-artifact scaffolding only when explicitly authorized.",
    "Preserve NO_SUBSTRATE_SELECTED.",
    "Preserve NO_ARTIFACT_SCORE.",
    "Preserve validation idempotence."
  ],
  "explicit_non_goals": [
    "No substrate artifact attempt.",
    "No rootfs generation.",
    "No store realization.",
    "No derivation build.",
    "No package build.",
    "No system activation.",
    "No runtime inspection.",
    "No substrate selection.",
    "No candidate ranking.",
    "No numeric WuciOS score.",
    "No Yocto execution.",
    "No OpenBSD runtime execution."
  ]
}
