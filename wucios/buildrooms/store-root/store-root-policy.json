{
  "schema": "wucios.euclid.store_root_policy.v1",
  "phase_id": "euclid-trial-phase-3c-c",
  "applies_to": [
    "nixos_store_root",
    "guix_store_root"
  ],
  "default_allowed_level": "L1_STORE_ROOT_POLICY_ONLY",
  "l2_scaffold_requires": "WUCIOS_PHASE3CC_ALLOW_L2_SCAFFOLD=1",
  "l3_artifact_attempts_allowed": false,
  "rootfs_generation_allowed": false,
  "store_realization_allowed": false,
  "derivation_build_allowed": false,
  "package_build_allowed": false,
  "system_activation_allowed": false,
  "network_allowed": false,
  "container_builds_allowed": false,
  "container_runs_allowed": false,
  "image_pulls_allowed": false,
  "sudo_allowed": false,
  "host_package_install_allowed": false,
  "source_clone_allowed": false,
  "os_image_download_allowed": false,
  "output_root": "build/wucios/buildrooms/store-root",
  "future_l3_requirements": [
    "explicit future authorization",
    "clean worktree",
    "approved store policy",
    "approved declarative input policy",
    "approved cache policy",
    "approved source/channel/flake identity policy",
    "candidate-specific evidence hooks",
    "Tarski Review Appliance integration",
    "NO_SUBSTRATE_SELECTED preserved until comparable evidence exists",
    "NO_ARTIFACT_SCORE preserved unless artifact-bound scoring is complete"
  ]
}
