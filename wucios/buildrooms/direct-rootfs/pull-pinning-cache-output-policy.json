{
  "schema": "wucios.euclid.direct_rootfs_pull_pinning_cache_output_policy.v1",
  "phase_id": "euclid-trial-phase-3c-b",
  "phase_3c_b": {
    "image_pulls_allowed": false,
    "network_allowed": false,
    "substrate_source_downloads_allowed": false,
    "os_image_downloads_allowed": false
  },
  "future_l3": {
    "base_images_must_be_pinned_by_digest_if_used": true,
    "local_source_tree_identity_must_be_recorded": true,
    "package_repository_urls_or_configs_must_be_recorded": true,
    "artifacts_root": "build/wucios/",
    "logs_root": "build/wucios/",
    "volatile_data_in_tracked_files_allowed": false,
    "artifact_manifest_and_hash_required_before_score": true,
    "cache_root": "build/wucios/cache/",
    "cache_root_override_requires_future_policy": true
  }
}
