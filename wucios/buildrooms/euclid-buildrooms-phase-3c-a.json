{
  "schema": "wucios.euclid.phase3c_a.plan.v1",
  "phase_id": "euclid-trial-phase-3c-a",
  "phase_name": "WuciOS v2.4 Euclid Trial Phase 3C-A — Rootless Backend Smoke and Buildroom Preparation Guardrails",
  "status": "CANDIDATE_TRIAL_PHASE",
  "default_execution_mode": "L1_SAFE_BACKEND_DETECTION",
  "l1_authorized_by_default": true,
  "l2_synthetic_smoke_authorized_by_default": false,
  "l2_synthetic_smoke_authorization_env": "WUCIOS_PHASE3CA_ALLOW_L2_SMOKE=1",
  "substrate_selection": "NO_SUBSTRATE_SELECTED",
  "ranking_allowed": false,
  "emotional_testing_allowed": false,
  "network_default": "DISABLED",
  "image_pulls_allowed": false,
  "substrate_artifact_attempts_allowed": false,
  "runtime_inspection_allowed": false,
  "container_runs_allowed": false,
  "vm_runs_allowed": false,
  "sudo_allowed": false,
  "host_package_install_allowed": false,
  "host_mutation_allowed": "TEMPORARY_ROOTLESS_SYNTHETIC_IMAGE_ONLY",
  "allowed_l1_actions": [
    "backend binary detection",
    "backend info commands",
    "readonly host checks",
    "guardrail negative tests",
    "ignored report generation"
  ],
  "allowed_l2_actions": [
    "generate local synthetic build context under build/wucios",
    "build FROM scratch synthetic smoke image with rootless podman or buildah",
    "use --pull=never or equivalent",
    "use --network=none or equivalent",
    "record image inspect data under build/wucios",
    "export OCI archive under build/wucios if supported",
    "remove synthetic smoke image after evidence capture"
  ],
  "forbidden_actions": [
    "substrate artifact attempt",
    "runtime inspection",
    "podman run",
    "buildah run",
    "docker run",
    "docker build",
    "image pull",
    "network use",
    "privileged container",
    "VM launch",
    "source clone",
    "OS image download",
    "package installation",
    "sudo",
    "substrate selection",
    "candidate ranking",
    "numeric WuciOS score"
  ],
  "objectives": [
    "Verify rootless backend mechanics without substrate inputs.",
    "Verify the evidence path for controlled buildroom preparation.",
    "Verify L3 artifact attempts remain blocked.",
    "Verify no WuciOS score is generated.",
    "Preserve NO_SUBSTRATE_SELECTED.",
    "Preserve REVIEW_PACKET_PARTIAL.",
    "Preserve validation idempotence."
  ]
}
