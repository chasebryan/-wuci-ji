{
  "schema": "wucios.euclid.backend_remediation_policy.v1",
  "phase_id": "euclid-trial-phase-3b-readiness",
  "safe_readiness_only": true,
  "allowed_detection_commands": [
    "command -v docker",
    "docker info",
    "command -v podman",
    "podman info",
    "command -v buildah",
    "buildah info",
    "command -v qemu-system-x86_64",
    "qemu-system-x86_64 --version",
    "command -v qemu-img",
    "qemu-img --version",
    "test -e /dev/kvm",
    "command -v nix",
    "command -v guix",
    "command -v xbps-install",
    "command -v xbps-query",
    "command -v apk",
    "command -v debootstrap",
    "command -v fakechroot",
    "command -v fakeroot",
    "command -v bitbake"
  ],
  "allowed_readonly_file_checks": [
    "/dev/kvm",
    "/var/run/docker.sock",
    "/run/docker.sock",
    "/etc/subuid",
    "/etc/subgid",
    "/etc/containers/storage.conf",
    "/etc/containers/containers.conf",
    "/proc/sys/kernel/unprivileged_userns_clone",
    "/proc/filesystems",
    "/proc/meminfo",
    "/proc/cpuinfo"
  ],
  "forbidden_actions": [
    "sudo",
    "su",
    "doas",
    "chmod docker socket",
    "edit /etc/subuid",
    "edit /etc/subgid",
    "edit container storage config",
    "start docker daemon",
    "start podman service",
    "docker pull",
    "docker build",
    "docker run",
    "podman pull",
    "podman build",
    "podman run",
    "buildah bud",
    "buildah from",
    "buildah run",
    "nix build",
    "guix system",
    "qemu-system execution",
    "VM launch",
    "package installation",
    "source tree cloning",
    "artifact download"
  ],
  "notes": [
    "This policy detects blockers only. It does not remediate the host.",
    "Human authorization is required before any host configuration change."
  ]
}
