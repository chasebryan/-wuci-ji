  "replacements": [
    {
      "label": "direct-file-policy-and-byte-budget",
      "encoding": "utf-8",
      "content": "## Noether: install only the exact signed and digest-locked APK files adjacent to this apkovl; do not use repository metadata, network indexes, kernel pkgs= additions, chart packages, tiny-cloud packages, or any other mounted media; failure exits PID 1 and stops boot. SHA-256 checked."
    },
    {
      "label": "wrapper-owned-install-policy",
      "encoding": "utf-8",
      "content": "apkflags=\"wrapper-enforces-no-network-and-exact-files\""
    },
    {
      "label": "overlay-stdin-wrapper-fail-closed",
      "encoding": "utf-8",
      "content": "if ! \"$sysroot\"/usr/local/sbin/wuci-install-locked-apks \"$sysroot\" \"$ovl\" overlay < \"$ovlfiles\"; then\n\t\texit 1\n\tfi"
    },
    {
      "label": "plain-wrapper-fail-closed",
      "encoding": "utf-8",
      "content": "if ! \"$sysroot\"/usr/local/sbin/wuci-install-locked-apks \"$sysroot\" \"$ovl\" plain; then\n\t\texit 1\n\tfi"
    }
  ]
