{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nosuchmachine.net/schemas/wucios/noether-forge-external-review.v1.json",
  "title": "WuciOS Noether Forge source-only external review policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_id",
    "status",
    "distribution_mode",
    "official_release",
    "public_release_authorized",
    "binary_assets_published",
    "external_validation_received",
    "reproducibility_scope",
    "third_party_binary_redistribution_review",
    "export_classification",
    "reviewer_build",
    "public_material",
    "excluded_material",
    "non_claims"
  ],
  "properties": {
    "schema": {"const": "wucios.noether_forge.external_review.v1"},
    "release_id": {"const": "noether-forge-v2.4.0"},
    "status": {"const": "review-requested"},
    "distribution_mode": {"const": "source-only"},
    "official_release": {"const": false},
    "public_release_authorized": {"const": false},
    "binary_assets_published": {"const": false},
    "external_validation_received": {"const": false},
    "reproducibility_scope": {"const": "same-checkout-repeat-build-only"},
    "third_party_binary_redistribution_review": {"const": "not-cleared-by-this-record"},
    "export_classification": {"const": "not-determined"},
    "reviewer_build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_fetches_upstream_inputs",
        "repository_mirrors_alpine_binaries",
        "commands"
      ],
      "properties": {
        "reviewer_fetches_upstream_inputs": {"const": true},
        "repository_mirrors_alpine_binaries": {"const": false},
        "commands": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "public_material": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "excluded_material": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
