{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WuciOS Euclid Phase 3C-E OpenBSD Reference Plan",
  "type": "object",
  "required": [
    "schema",
    "phase_id",
    "phase_name",
    "default_execution_mode",
    "l2_scaffold_authorized_by_default",
    "l2_scaffold_authorization_env",
    "l3_substrate_artifact_attempts_allowed",
    "runtime_inspection_allowed",
    "substrate_selection",
    "ranking_allowed",
    "numeric_score_allowed",
    "in_scope_references",
    "forbidden_actions"
  ],
  "properties": {
    "schema": {"const": "wucios.euclid.phase3c_e.plan.v1"},
    "phase_id": {"const": "euclid-trial-phase-3c-e"},
    "phase_name": {"type": "string"},
    "default_execution_mode": {"const": "L1_OPENBSD_REFERENCE_POLICY_AND_INPUTS"},
    "l2_scaffold_authorized_by_default": {"const": false},
    "l2_scaffold_authorization_env": {"const": "WUCIOS_PHASE3CE_ALLOW_L2_SCAFFOLD=1"},
    "l3_substrate_artifact_attempts_allowed": {"const": false},
    "runtime_inspection_allowed": {"const": false},
    "substrate_selection": {"const": "NO_SUBSTRATE_SELECTED"},
    "ranking_allowed": {"const": false},
    "numeric_score_allowed": {"const": false},
    "in_scope_references": {"type": "array", "items": {"const": "openbsd_reference"}},
    "forbidden_actions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
