{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nosuchmachine.net/schemas/wucios/noether-forge-physical-hardware-observation.v1.json",
  "title": "WuciOS Noether Forge digest-bound physical-hardware observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "release_id", "record_status", "subject", "observation", "claim_boundary"],
  "properties": {
    "schema": {"const": "wucios.noether_forge.physical_hardware_observation.v1"},
    "release_id": {"const": "noether-forge-v2.4.0"},
    "record_status": {"enum": ["fixture-only", "operator-observation"]},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_kind", "subject_description", "commit", "iso_filename", "iso_digests"],
      "properties": {
        "subject_kind": {"enum": ["synthetic-fixture", "private-reviewer-built-iso"]},
        "subject_description": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "iso_filename": {"type": "string", "minLength": 1},
        "iso_digests": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sha256", "sha384", "sha512"],
          "properties": {
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "sha384": {"type": "string", "pattern": "^[0-9a-f]{96}$"},
            "sha512": {"type": "string", "pattern": "^[0-9a-f]{128}$"}
          }
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_at_utc",
        "operator_id",
        "hardware",
        "firmware",
        "capture_host",
        "tools",
        "observations"
      ],
      "properties": {
        "observed_at_utc": {"type": "string", "format": "date-time"},
        "operator_id": {"type": "string", "minLength": 1},
        "hardware": {
          "type": "object",
          "additionalProperties": false,
          "required": ["manufacturer", "model", "architecture", "identifiers_redacted"],
          "properties": {
            "manufacturer": {"type": "string", "minLength": 1},
            "model": {"type": "string", "minLength": 1},
            "architecture": {"type": "string", "minLength": 1},
            "identifiers_redacted": {"const": true}
          }
        },
        "firmware": {
          "type": "object",
          "additionalProperties": false,
          "required": ["boot_mode", "vendor", "version", "secure_boot"],
          "properties": {
            "boot_mode": {"enum": ["bios", "uefi", "other"]},
            "vendor": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "secure_boot": {"enum": ["enabled", "disabled", "not-observed", "not-applicable"]}
          }
        },
        "capture_host": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operating_system", "kernel", "architecture"],
          "properties": {
            "operating_system": {"type": "string", "minLength": 1},
            "kernel": {"type": "string", "minLength": 1},
            "architecture": {"type": "string", "minLength": 1}
          }
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version", "purpose"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "version": {"type": "string", "minLength": 1},
              "purpose": {"type": "string", "minLength": 1}
            }
          }
        },
        "observations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "result", "notes"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "result": {"enum": ["observed", "not-observed", "not-tested"]},
              "notes": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hardware_validation_claimed",
        "external_validation_claimed",
        "official_release_claimed",
        "production_authority_claimed",
        "statement"
      ],
      "properties": {
        "hardware_validation_claimed": {"const": false},
        "external_validation_claimed": {"const": false},
        "official_release_claimed": {"const": false},
        "production_authority_claimed": {"const": false},
        "statement": {
          "const": "This record is a digest-bound operator observation only; it is not independent hardware validation, certification, official release authority, or proof of OS containment."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"record_status": {"const": "fixture-only"}}},
      "then": {
        "properties": {
          "subject": {"properties": {"subject_kind": {"const": "synthetic-fixture"}}}
        }
      }
    },
    {
      "if": {"properties": {"record_status": {"const": "operator-observation"}}},
      "then": {
        "properties": {
          "subject": {
            "properties": {
              "subject_kind": {"const": "private-reviewer-built-iso"},
              "commit": {"not": {"const": "0000000000000000000000000000000000000000"}}
            }
          }
        }
      }
    }
  ]
}
