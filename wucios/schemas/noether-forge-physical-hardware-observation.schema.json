{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nosuchmachine.net/schemas/wucios/noether-forge-physical-hardware-observation.v1.json",
  "title": "WuciOS Noether Forge digest-bound physical-hardware observation",
  "description": "A size-bounded, structured observation record. Mutable fields are enums, identifiers, versions, redaction tokens, or digests; the contract has no operator prose lane.",
  "x-maxUtf8Bytes": 131072,
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "release_id", "record_status", "subject", "observation", "claim_boundary"],
  "$defs": {
    "lowercaseIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9._+-]{0,62}[a-z0-9])?$"
    },
    "versionIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._+-]{0,62}[A-Za-z0-9])?$"
    },
    "metadataToken": {
      "type": "string",
      "minLength": 1,
      "maxLength": 72,
      "oneOf": [
        {"enum": ["redacted", "not-observed", "fixture-not-observed"]},
        {"pattern": "^sha256:[0-9a-f]{64}$"}
      ]
    },
    "versionToken": {
      "type": "string",
      "minLength": 1,
      "maxLength": 72,
      "oneOf": [
        {"enum": ["redacted", "not-observed", "fixture-not-observed"]},
        {"pattern": "^sha256:[0-9a-f]{64}$"},
        {"pattern": "^version:[A-Za-z0-9](?:[A-Za-z0-9._+-]{0,62}[A-Za-z0-9])?$"}
      ]
    },
    "architecture": {
      "enum": ["x86_64", "aarch64", "riscv64", "not-observed", "fixture-not-observed"]
    },
    "toolPurpose": {
      "enum": [
        "record-shape-check",
        "iso-digest-comparison",
        "boot-observation-capture",
        "firmware-state-observation",
        "local-runtime-status-observation",
        "private-media-hash-recording"
      ]
    },
    "observationName": {
      "enum": [
        "fixture-record-shape",
        "boot-menu-visible",
        "kernel-start-visible",
        "local-tty-login-prompt-visible",
        "release-notes-visible",
        "local-runtime-status-visible",
        "shutdown-completed"
      ]
    },
    "observationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "result", "notes"],
      "properties": {
        "name": {"$ref": "#/$defs/observationName"},
        "result": {"enum": ["observed", "not-observed", "not-tested"]},
        "notes": {
          "enum": [
            "observed-on-attached-display",
            "observed-on-local-console",
            "observed-in-private-capture",
            "observed-without-retained-capture",
            "not-observed-during-session",
            "not-tested",
            "fixture-shape-only"
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"result": {"const": "observed"}}, "required": ["result"]},
          "then": {
            "properties": {
              "notes": {
                "enum": [
                  "observed-on-attached-display",
                  "observed-on-local-console",
                  "observed-in-private-capture",
                  "observed-without-retained-capture"
                ]
              }
            }
          }
        },
        {
          "if": {"properties": {"result": {"const": "not-observed"}}, "required": ["result"]},
          "then": {"properties": {"notes": {"const": "not-observed-during-session"}}}
        },
        {
          "if": {"properties": {"result": {"const": "not-tested"}}, "required": ["result"]},
          "then": {"properties": {"notes": {"enum": ["not-tested", "fixture-shape-only"]}}}
        }
      ]
    }
  },
  "properties": {
    "schema": {"const": "wucios.noether_forge.physical_hardware_observation.v1"},
    "release_id": {"const": "noether-forge-v2.4.0"},
    "record_status": {"enum": ["fixture-only", "operator-observation"]},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_kind", "subject_description", "commit", "iso_filename", "iso_digests"],
      "properties": {
        "subject_kind": {"enum": ["synthetic-fixture", "private-reviewer-built-iso"]},
        "subject_description": {"enum": ["synthetic-fixture-marker-only", "private-reviewer-built-iso"]},
        "commit": {"type": "string", "minLength": 40, "maxLength": 40, "pattern": "^[0-9a-f]{40}$"},
        "iso_filename": {
          "enum": [
            "NOT-A-RELEASE-noether-hardware-observation-fixture.iso",
            "WuciOS-v2.4.0-Noether-Forge-x86_64.iso"
          ]
        },
        "iso_digests": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sha256", "sha384", "sha512"],
          "properties": {
            "sha256": {"type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[0-9a-f]{64}$"},
            "sha384": {"type": "string", "minLength": 96, "maxLength": 96, "pattern": "^[0-9a-f]{96}$"},
            "sha512": {"type": "string", "minLength": 128, "maxLength": 128, "pattern": "^[0-9a-f]{128}$"}
          }
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_at_utc",
        "operator_id",
        "hardware",
        "firmware",
        "capture_host",
        "tools",
        "observations"
      ],
      "properties": {
        "observed_at_utc": {
          "type": "string",
          "minLength": 20,
          "maxLength": 20,
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "operator_id": {"$ref": "#/$defs/lowercaseIdentifier"},
        "hardware": {
          "type": "object",
          "additionalProperties": false,
          "required": ["manufacturer", "model", "architecture", "identifiers_redacted"],
          "properties": {
            "manufacturer": {"$ref": "#/$defs/metadataToken"},
            "model": {"$ref": "#/$defs/metadataToken"},
            "architecture": {"$ref": "#/$defs/architecture"},
            "identifiers_redacted": {"const": true}
          }
        },
        "firmware": {
          "type": "object",
          "additionalProperties": false,
          "required": ["boot_mode", "vendor", "version", "secure_boot"],
          "properties": {
            "boot_mode": {"enum": ["bios", "uefi", "not-observed", "fixture-not-observed"]},
            "vendor": {"$ref": "#/$defs/metadataToken"},
            "version": {"$ref": "#/$defs/versionToken"},
            "secure_boot": {"enum": ["enabled", "disabled", "not-observed", "not-applicable", "fixture-not-observed"]}
          }
        },
        "capture_host": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operating_system", "kernel", "architecture"],
          "properties": {
            "operating_system": {
              "enum": [
                "linux", "windows", "macos", "freebsd", "openbsd", "netbsd",
                "redacted", "not-observed", "fixture-not-observed"
              ]
            },
            "kernel": {"$ref": "#/$defs/versionToken"},
            "architecture": {"$ref": "#/$defs/architecture"}
          }
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version", "purpose"],
            "properties": {
              "name": {"$ref": "#/$defs/lowercaseIdentifier"},
              "version": {"$ref": "#/$defs/versionIdentifier"},
              "purpose": {"$ref": "#/$defs/toolPurpose"}
            }
          }
        },
        "observations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/observationItem"}
        }
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hardware_validation_claimed",
        "external_validation_claimed",
        "official_release_claimed",
        "production_authority_claimed",
        "statement"
      ],
      "properties": {
        "hardware_validation_claimed": {"const": false},
        "external_validation_claimed": {"const": false},
        "official_release_claimed": {"const": false},
        "production_authority_claimed": {"const": false},
        "statement": {
          "const": "This record is a digest-bound operator observation only; it is not independent hardware validation, certification, official release authority, or proof of OS containment."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"record_status": {"const": "fixture-only"}}, "required": ["record_status"]},
      "then": {
        "properties": {
          "subject": {
            "properties": {
              "subject_kind": {"const": "synthetic-fixture"},
              "subject_description": {"const": "synthetic-fixture-marker-only"},
              "iso_filename": {"const": "NOT-A-RELEASE-noether-hardware-observation-fixture.iso"}
            }
          },
          "observation": {
            "properties": {
              "operator_id": {"const": "fixture-only"},
              "hardware": {
                "properties": {
                  "manufacturer": {"const": "fixture-not-observed"},
                  "model": {"const": "fixture-not-observed"},
                  "architecture": {"const": "fixture-not-observed"}
                }
              },
              "firmware": {
                "properties": {
                  "boot_mode": {"const": "fixture-not-observed"},
                  "vendor": {"const": "fixture-not-observed"},
                  "version": {"const": "fixture-not-observed"},
                  "secure_boot": {"const": "fixture-not-observed"}
                }
              },
              "capture_host": {
                "properties": {
                  "operating_system": {"const": "fixture-not-observed"},
                  "kernel": {"const": "fixture-not-observed"},
                  "architecture": {"const": "fixture-not-observed"}
                }
              },
              "tools": {
                "const": [
                  {
                    "name": "noether_hardware_observation.py",
                    "version": "v1",
                    "purpose": "record-shape-check"
                  }
                ]
              },
              "observations": {
                "const": [
                  {
                    "name": "fixture-record-shape",
                    "result": "not-tested",
                    "notes": "fixture-shape-only"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"record_status": {"const": "operator-observation"}}, "required": ["record_status"]},
      "then": {
        "properties": {
          "subject": {
            "properties": {
              "subject_kind": {"const": "private-reviewer-built-iso"},
              "subject_description": {"const": "private-reviewer-built-iso"},
              "commit": {"not": {"const": "0000000000000000000000000000000000000000"}},
              "iso_filename": {"const": "WuciOS-v2.4.0-Noether-Forge-x86_64.iso"}
            }
          },
          "observation": {
            "properties": {
              "operator_id": {"not": {"const": "fixture-only"}},
              "hardware": {
                "properties": {
                  "manufacturer": {"not": {"const": "fixture-not-observed"}},
                  "model": {"not": {"const": "fixture-not-observed"}},
                  "architecture": {"not": {"const": "fixture-not-observed"}}
                }
              },
              "firmware": {
                "properties": {
                  "boot_mode": {"not": {"const": "fixture-not-observed"}},
                  "vendor": {"not": {"const": "fixture-not-observed"}},
                  "version": {"not": {"const": "fixture-not-observed"}},
                  "secure_boot": {"not": {"const": "fixture-not-observed"}}
                }
              },
              "capture_host": {
                "properties": {
                  "operating_system": {"not": {"const": "fixture-not-observed"}},
                  "kernel": {"not": {"const": "fixture-not-observed"}},
                  "architecture": {"not": {"const": "fixture-not-observed"}}
                }
              },
              "observations": {
                "not": {
                  "contains": {
                    "anyOf": [
                      {"properties": {"name": {"const": "fixture-record-shape"}}, "required": ["name"]},
                      {"properties": {"notes": {"const": "fixture-shape-only"}}, "required": ["notes"]}
                    ]
                  }
                },
                "contains": {
                  "properties": {"result": {"const": "observed"}},
                  "required": ["result"]
                },
                "minContains": 1
              }
            }
          }
        }
      }
    }
  ]
}
