{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nosuchmachine.net/schemas/wucios/noether-forge-release-contract.v1.json",
  "title": "WuciOS Noether Forge release contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "product",
    "version",
    "codename",
    "release_id",
    "profile",
    "architecture",
    "artifact_filename",
    "volume_id",
    "source_date_epoch",
    "substrate",
    "authorization",
    "runtime_contract",
    "publication_holds",
    "non_claims"
  ],
  "properties": {
    "schema": {"const": "wucios.noether_forge.release.v1"},
    "product": {"const": "WuciOS"},
    "version": {"const": "2.4.0"},
    "codename": {"const": "Noether Forge"},
    "release_id": {"const": "noether-forge-v2.4.0"},
    "profile": {"const": "noether-core"},
    "architecture": {"const": "x86_64"},
    "artifact_filename": {"const": "WuciOS-v2.4.0-Noether-Forge-x86_64.iso"},
    "volume_id": {"const": "WuciOS 2.4 Noether Forge"},
    "source_date_epoch": {"type": "integer", "minimum": 1},
    "substrate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distribution", "version", "kernel", "libc", "init"],
      "properties": {
        "distribution": {"const": "Alpine Linux"},
        "version": {"const": "3.24.1"},
        "kernel": {"const": "6.18.35-0-lts"},
        "libc": {"const": "musl"},
        "init": {"const": "OpenRC"}
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "opened_by", "public_release_authorized"],
      "properties": {
        "scope": {"type": "string", "minLength": 1},
        "opened_by": {"type": "string", "minLength": 1},
        "public_release_authorized": {"const": false}
      }
    },
    "runtime_contract": {"type": "object"},
    "publication_holds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
