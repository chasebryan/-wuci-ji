{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "dependency_digests": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "event_horizon_scorecard_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "executable_metadata": {
      "additionalProperties": false,
      "properties": {
        "executable_bit": {
          "type": "boolean"
        },
        "format": {
          "type": "string"
        },
        "host_trust_level": {
          "type": "string"
        },
        "mode_octal": {
          "pattern": "^[0-7]{4}$",
          "type": "string"
        },
        "runtime_containment_claim": {
          "const": false,
          "type": "boolean"
        }
      },
      "required": [
        "format",
        "mode_octal",
        "executable_bit",
        "host_trust_level",
        "runtime_containment_claim"
      ],
      "type": "object"
    },
    "file_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "file_sha3_512": {
      "pattern": "^[0-9a-f]{128}$",
      "type": "string"
    },
    "policy_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "previous_vector_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "section_digests": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "offset": {
            "minimum": 0,
            "type": "integer"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "sha3_512": {
            "pattern": "^[0-9a-f]{128}$",
            "type": "string"
          },
          "size_bytes": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "id",
          "offset",
          "size_bytes",
          "sha256",
          "sha3_512"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "size_bytes": {
      "minimum": 0,
      "type": "integer"
    },
    "subject_kind": {
      "const": "file",
      "type": "string"
    },
    "subject_path_normalized": {
      "type": "string"
    },
    "user_verification_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "vector_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "version": {
      "const": "daylight-v18-binaric-vector-v0.1",
      "type": "string"
    }
  },
  "required": [
    "version",
    "subject_kind",
    "subject_path_normalized",
    "file_sha256",
    "file_sha3_512",
    "size_bytes",
    "executable_metadata",
    "section_digests",
    "dependency_digests",
    "event_horizon_scorecard_digest",
    "policy_digest",
    "vector_digest"
  ],
  "title": "Daylight v18 Binaric Vector",
  "type": "object"
}
