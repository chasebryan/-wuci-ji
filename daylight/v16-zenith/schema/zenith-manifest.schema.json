{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daylight v16 Zenith Manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "artifact",
    "generated_date",
    "inputs",
    "outputs",
    "zenith_report_digest",
    "zenith_resolution_digest",
    "solstice_score_M",
    "zenith_adjusted_score_M",
    "score_inflation_M",
    "zenith_assurance_M",
    "zenith_level",
    "dz1_pass",
    "dz2_production_eligible"
  ],
  "properties": {
    "manifest_version": {"type": "string", "const": "daylight-v16-zenith-manifest-v0.1"},
    "artifact": {"type": "string", "const": "Daylight v16 Zenith"},
    "generated_date": {"type": "string", "const": "2026-07-01"},
    "inputs": {"type": "object"},
    "outputs": {"type": "object"},
    "zenith_report_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "zenith_resolution_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "solstice_score_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "zenith_adjusted_score_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "score_inflation_M": {"type": "integer", "const": 0},
    "zenith_assurance_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "zenith_level": {"type": "string"},
    "dz1_pass": {"type": "boolean"},
    "dz2_production_eligible": {"type": "boolean"}
  }
}
