{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daylight v16 Zenith Report",
  "type": "object",
  "required": [
    "report_version",
    "name",
    "version",
    "solstice_score_M",
    "zenith_adjusted_score_M",
    "score_inflation_M",
    "zenith_assurance_M",
    "zenith_level",
    "dz1_pass",
    "dz2_production_eligible",
    "zenith_axis_digest",
    "zenith_obligation_digest",
    "zenith_resolution_digest",
    "axis_values",
    "axis_contributions_M",
    "closed_zenith_obligations",
    "open_zenith_obligations",
    "boundary_claims",
    "non_claims"
  ],
  "properties": {
    "report_version": {"type": "string", "const": "daylight-v16-zenith-report-v0.1"},
    "name": {"type": "string", "const": "Daylight v16 Zenith"},
    "version": {"type": "string", "const": "daylight-v16-zenith-v0.1"},
    "solstice_score_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "zenith_adjusted_score_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "score_inflation_M": {"type": "integer", "const": 0},
    "zenith_assurance_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "zenith_level": {"type": "string"},
    "dz1_pass": {"type": "boolean"},
    "dz2_production_eligible": {"type": "boolean"},
    "zenith_axis_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "zenith_obligation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "zenith_resolution_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "axis_values": {"type": "object"},
    "axis_contributions_M": {"type": "object"},
    "closed_zenith_obligations": {"type": "array", "items": {"type": "string"}},
    "open_zenith_obligations": {"type": "array", "items": {"type": "string"}},
    "boundary_claims": {"type": "object"},
    "non_claims": {"type": "array", "items": {"type": "string"}}
  }
}
