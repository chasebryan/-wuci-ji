{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aperture-singularity-capsule.schema.json",
  "title": "Daylight v20 Aperture Singularity Capsule",
  "description": "Documentation schema. The enforced validator is src/singularity_gate.py:validate_capsule, which recomputes the capsule digest, declaration blockers, and claim-boundary invariants.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "project",
    "layer_name",
    "generated_by",
    "source_commit",
    "release_tag",
    "fixture",
    "claim_usable",
    "input_aperture_capsule_digest",
    "input_aperture_firewall_report_digest",
    "input_firewall_profile_expansion_digest",
    "input_verifier_agreement_bundle_digest",
    "input_external_attestation_bundle_digest",
    "input_reproducible_build_bundle_digest",
    "input_falsification_bundle_digest",
    "input_boundary_debt_report_digest",
    "input_meridian_scorecard_digest",
    "input_event_horizon_scorecard_digest",
    "input_binaric_vector_chain_digest",
    "input_transition_ledger_head",
    "policy_digest",
    "proof_fields",
    "omega_sum",
    "omega_weak",
    "omega_eff",
    "score_AM_plus",
    "score_inflation_M",
    "critical_debt",
    "contradiction_debt",
    "field_thresholds_passed",
    "fracture_suite_passed",
    "cross_verifier_agreement_passed",
    "verifier_quorum",
    "external_attestation_verified",
    "reserved_perfect_value_used",
    "verifier_agreement",
    "external_attestation_summary",
    "reproducible_build_summary",
    "falsification_summary",
    "boundary_debt_summary",
    "firewall_profile_summary",
    "claim_boundary",
    "non_claims",
    "blockers",
    "declaration_allowed",
    "capsule_digest"
  ],
  "properties": {
    "schema_id": {"const": "daylight-v20-aperture-singularity-capsule"},
    "schema_version": {"const": "0.1.0"},
    "project": {"const": "wuci-ji"},
    "layer_name": {"const": "Daylight v20 - Aperture Singularity Gate"},
    "generated_by": {"type": "string", "pattern": "^daylight-v20-aperture-singularity/"},
    "source_commit": {"type": "string"},
    "release_tag": {"type": "string"},
    "fixture": {"type": "boolean"},
    "claim_usable": {"type": "boolean"},
    "input_aperture_capsule_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_aperture_firewall_report_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_firewall_profile_expansion_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_verifier_agreement_bundle_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_external_attestation_bundle_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_reproducible_build_bundle_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_falsification_bundle_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_boundary_debt_report_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_meridian_scorecard_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "input_event_horizon_scorecard_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "input_binaric_vector_chain_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "input_transition_ledger_head": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "policy_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "proof_fields": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5
    },
    "omega_sum": {"type": "string"},
    "omega_weak": {"type": "string"},
    "omega_eff": {"type": "string"},
    "score_AM_plus": {"type": "integer", "minimum": 0, "maximum": 999999999},
    "score_inflation_M": {"type": "integer"},
    "critical_debt": {"type": "integer", "minimum": 0},
    "contradiction_debt": {"type": "integer", "minimum": 0},
    "field_thresholds_passed": {"type": "boolean"},
    "fracture_suite_passed": {"type": "boolean"},
    "cross_verifier_agreement_passed": {"type": "boolean"},
    "verifier_quorum": {"type": "string"},
    "external_attestation_verified": {"type": "boolean"},
    "reserved_perfect_value_used": {"type": "boolean"},
    "verifier_agreement": {"type": "object"},
    "external_attestation_summary": {"type": "object"},
    "reproducible_build_summary": {"type": "object"},
    "falsification_summary": {"type": "object"},
    "boundary_debt_summary": {"type": "object"},
    "firewall_profile_summary": {"type": "object"},
    "claim_boundary": {"type": "object"},
    "non_claims": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "declaration_allowed": {"type": "boolean"},
    "capsule_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
