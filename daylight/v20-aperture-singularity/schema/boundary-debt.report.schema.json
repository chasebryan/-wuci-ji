{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "boundary-debt.report.schema.json",
  "title": "Daylight v20 Boundary Debt Report",
  "description": "Documentation schema. The enforced validator is src/boundary_debt.py:evaluate_report.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "fixture",
    "claim_usable",
    "score_inflation_M",
    "manual_score_override",
    "reserved_perfect_AM_plus_used",
    "claim_boundary",
    "non_claims",
    "debts"
  ],
  "properties": {
    "schema_id": {"const": "daylight-v20-boundary-debt-report"},
    "schema_version": {"const": "0.1.0"},
    "fixture": {"type": "boolean"},
    "claim_usable": {"type": "boolean"},
    "score_inflation_M": {"type": "integer"},
    "manual_score_override": {"type": "boolean"},
    "reserved_perfect_AM_plus_used": {"type": "boolean"},
    "claim_boundary": {"type": "object"},
    "non_claims": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "debts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "debt_id",
          "debt_class",
          "description",
          "evidence_digest_optional"
        ],
        "properties": {
          "debt_id": {"type": "string", "minLength": 1},
          "debt_class": {"enum": ["none", "minor", "major", "critical", "contradiction"]},
          "description": {"type": "string", "minLength": 1},
          "evidence_digest_optional": {"type": ["string", "null"]}
        }
      }
    }
  }
}
