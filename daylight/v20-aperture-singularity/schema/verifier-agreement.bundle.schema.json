{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "verifier-agreement.bundle.schema.json",
  "title": "Daylight v20 Verifier Agreement Bundle",
  "description": "Documentation schema. The enforced validator is src/verifier_agreement.py:evaluate_bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "subject",
    "vectors"
  ],
  "properties": {
    "schema_id": {"const": "daylight-v20-verifier-agreement-bundle"},
    "schema_version": {"const": "0.1.0"},
    "subject": {"type": "string", "minLength": 1},
    "vectors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "vector_id",
          "verifier_family",
          "implementation_digest",
          "canonical_output_digest",
          "output_schema_id",
          "vector_digest",
          "fixture",
          "claim_usable"
        ],
        "properties": {
          "vector_id": {"type": "string", "minLength": 1},
          "verifier_family": {"type": "string", "minLength": 1},
          "implementation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "canonical_output_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "output_schema_id": {"const": "daylight-v20-aperture-singularity-capsule"},
          "vector_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "fixture": {"type": "boolean"},
          "claim_usable": {"type": "boolean"}
        }
      }
    }
  }
}
