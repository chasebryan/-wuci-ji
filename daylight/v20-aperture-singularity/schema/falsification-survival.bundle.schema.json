{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "falsification-survival.bundle.schema.json",
  "title": "Daylight v20 Falsification Survival Bundle",
  "description": "Documentation schema. The enforced validator is src/falsification.py:evaluate_bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "fixture",
    "claim_usable",
    "authority_scope",
    "non_claims_acknowledged",
    "results"
  ],
  "properties": {
    "schema_id": {"const": "daylight-v20-falsification-survival-bundle"},
    "schema_version": {"const": "0.1.0"},
    "fixture": {"type": "boolean"},
    "claim_usable": {"type": "boolean"},
    "authority_scope": {"const": "repo-owned-negative-corpus"},
    "non_claims_acknowledged": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "description",
          "outcome",
          "evidence_digest"
        ],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "outcome": {"enum": ["rejected", "blocked"]},
          "evidence_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
