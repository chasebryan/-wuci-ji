{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "external_rebuild_receipt.v20.json",
  "title": "Daylight v20.2 External Rebuild Receipt",
  "description": "Documentation schema for one standalone external rebuild receipt. The enforced validator is src/rebuild_receipts.py. A receipt is accepted only if the reviewer identity is external, the checkout is declared clean, expected artifact digests match the pinned release subject, produced artifact digests match expected artifact digests, the transcript digest is non-placeholder, every non-claim is acknowledged, receipt_statement_digest recomputes over the receipt without receipt_statement_digest and attestation_ref, and attestation_ref is a pinned Ed25519 attestation whose subject_digest equals the recomputed receipt statement digest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "receipt_kind",
    "reviewer_identity",
    "reviewer_independence_class",
    "fixture",
    "claim_usable",
    "source_repo",
    "source_commit",
    "source_tag",
    "clean_checkout_declared",
    "build_commands",
    "environment",
    "expected_artifact",
    "produced_artifact",
    "transcript_digest",
    "receipt_statement_digest",
    "attestation_ref",
    "nonclaim_acknowledgement"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "receipt_id": {"type": "string", "minLength": 1},
    "receipt_kind": {"const": "daylight-v20-independent-rebuild-receipt"},
    "reviewer_identity": {"type": "string", "minLength": 1},
    "reviewer_independence_class": {"const": "external"},
    "fixture": {"type": "boolean"},
    "claim_usable": {"type": "boolean"},
    "source_repo": {"type": "string", "minLength": 1},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source_tag": {"type": "string", "minLength": 1},
    "clean_checkout_declared": {"const": true},
    "build_commands": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os_name",
        "os_version",
        "architecture",
        "shell",
        "tool_versions",
        "containerized",
        "notes"
      ],
      "properties": {
        "os_name": {"type": "string"},
        "os_version": {"type": "string"},
        "architecture": {"type": "string"},
        "shell": {"type": "string"},
        "tool_versions": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1},
          "minProperties": 1
        },
        "containerized": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    },
    "expected_artifact": {"$ref": "#/definitions/artifact"},
    "produced_artifact": {"$ref": "#/definitions/artifact"},
    "transcript_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "receipt_statement_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "attestation_ref": {"$ref": "pinned-attestation.schema.json"},
    "nonclaim_acknowledgement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_production_crypto_claim",
        "no_runtime_containment_claim",
        "no_whole_system_post_quantum_safety_claim",
        "no_external_certification_claim",
        "no_perfect_score_claim",
        "no_singularity_claim_from_this_receipt_alone"
      ],
      "properties": {
        "no_production_crypto_claim": {"const": true},
        "no_runtime_containment_claim": {"const": true},
        "no_whole_system_post_quantum_safety_claim": {"const": true},
        "no_external_certification_claim": {"const": true},
        "no_perfect_score_claim": {"const": true},
        "no_singularity_claim_from_this_receipt_alone": {"const": true}
      }
    }
  },
  "definitions": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_name",
        "sha256",
        "sha3_512",
        "byte_count",
        "public_manifest_digest"
      ],
      "properties": {
        "artifact_name": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "sha3_512": {"type": "string", "pattern": "^[0-9a-f]{128}$"},
        "byte_count": {"type": "integer", "minimum": 0},
        "public_manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
