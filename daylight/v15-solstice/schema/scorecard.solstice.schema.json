{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daylight v15+ Solstice Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scorecard_version",
    "candidate",
    "status",
    "generated",
    "manual_override",
    "manual_edit_allowed",
    "score_body",
    "score_body_digest",
    "reproducibility_receipt_digest",
    "score_entry_digest",
    "input_ledger_head",
    "output_ledger_head",
    "artifact_manifest_digest",
    "scorecard_digest"
  ],
  "properties": {
    "scorecard_version": {"type": "string", "const": "daylight-v15-solstice-scorecard-v0.1"},
    "candidate": {"type": "string", "const": "DAYLIGHT v15+ SOLSTICE HERMETIC FRONTIER"},
    "status": {
      "type": "string",
      "enum": [
        "solstice_internal_ceiling_external_frontier_open",
        "solstice_partial_internal_evidence",
        "solstice_external_partially_closed",
        "solstice_perfect_external_closed",
        "solstice_rejected"
      ]
    },
    "generated": {"type": "boolean", "const": true},
    "manual_override": {"type": "boolean", "const": false},
    "manual_edit_allowed": {"type": "boolean", "const": false},
    "score_body": {
      "type": "object",
      "required": [
        "score_body_version",
        "obligations_digest",
        "weight_vector_digest",
        "evidence_resolution_digest",
        "q_vector",
        "term_contributions_M",
        "final_score_M",
        "perfect_score_M",
        "residue_to_perfect_M",
        "claim_boundary"
      ]
    },
    "score_body_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reproducibility_receipt_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "score_entry_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_ledger_head": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "output_ledger_head": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact_manifest_digest": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^[0-9a-f]{64}$"}]},
    "scorecard_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
