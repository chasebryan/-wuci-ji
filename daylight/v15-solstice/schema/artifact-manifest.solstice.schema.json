{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daylight v15+ Solstice Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "artifact",
    "package_version",
    "generated_date",
    "command",
    "inputs",
    "outputs",
    "score_body_digest",
    "scorecard_digest",
    "receipt_digest",
    "score_entry_digest",
    "output_ledger_head",
    "final_score_M",
    "internal_ceiling_M",
    "external_residue_M",
    "residue_to_perfect_M",
    "boundary",
    "artifact_manifest_digest"
  ],
  "properties": {
    "manifest_version": {"type": "string", "const": "daylight-v15-solstice-artifact-manifest-v0.1"},
    "artifact": {"type": "string", "const": "Daylight v15+ Solstice"},
    "package_version": {"type": "string"},
    "generated_date": {"type": "string", "const": "2026-07-01"},
    "command": {"type": "string"},
    "inputs": {"type": "object"},
    "outputs": {"type": "object"},
    "score_body_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scorecard_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "receipt_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "score_entry_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "output_ledger_head": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "final_score_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "internal_ceiling_M": {"type": "integer"},
    "external_residue_M": {"type": "integer"},
    "residue_to_perfect_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "boundary": {"type": "object"},
    "artifact_manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
