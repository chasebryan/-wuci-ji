{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daylight v15 Meridian Obligation Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "scale", "harness_identity", "dimensions"],
  "properties": {
    "version": {"type": "string", "const": "daylight-v15-meridian-obligations-v0.1"},
    "scale": {"type": "string", "const": "thousandths"},
    "harness_identity": {"type": "string", "minLength": 1},
    "note": {"type": "string"},
    "dimensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "obligations"],
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "obligations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "weight", "scope", "evidence_kind", "evidence_class"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "weight": {"type": "integer", "minimum": 1, "maximum": 1000},
                "scope": {"type": "string", "enum": ["internal", "external"]},
                "evidence_kind": {"type": "string", "enum": ["ledger", "corpus"]},
                "evidence_class": {"type": "string", "minLength": 1},
                "external_role": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    }
  }
}
