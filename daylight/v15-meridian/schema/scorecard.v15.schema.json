{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daylight v15 Meridian Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scorecard_version",
    "candidate",
    "status",
    "generated",
    "manual_override",
    "manual_edit_allowed",
    "weight_vector_ref",
    "obligations_version",
    "obligations_digest",
    "q_vector",
    "term_contributions_M",
    "unified_score_rational",
    "unified_score_decimal",
    "final_score_M",
    "perfect_score_M",
    "residue_to_perfect_M",
    "closed_obligations",
    "open_obligations",
    "input_ledger_head",
    "output_ledger_head",
    "corpus_snapshot_digest",
    "reproducibility_receipt_digest",
    "scorecard_digest"
  ],
  "properties": {
    "scorecard_version": {"type": "string", "const": "daylight-v15-meridian-scorecard-v0.1"},
    "candidate": {"type": "string", "const": "DAYLIGHT v15 MERIDIAN ASCENDANT CANDIDATE"},
    "status": {
      "type": "string",
      "enum": [
        "candidate_score_internal_ceiling_external_frontier_open",
        "candidate_score_internal_complete_no_open_external_frontier",
        "perfect_score_pending_external_release_gate"
      ]
    },
    "generated": {"type": "boolean", "const": true},
    "manual_override": {"type": "boolean", "const": false},
    "manual_edit_allowed": {"type": "boolean", "const": false},
    "weight_vector_ref": {"type": "string", "const": "daylight-v13-weight-vector"},
    "obligations_version": {"type": "string", "const": "daylight-v15-meridian-obligations-v0.1"},
    "obligations_digest": {"type": "string", "minLength": 64},
    "q_vector": {"type": "array"},
    "term_contributions_M": {"type": "array"},
    "unified_score_rational": {"type": "string"},
    "unified_score_decimal": {"type": "string"},
    "final_score_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "perfect_score_M": {"type": "integer", "const": 1000000},
    "residue_to_perfect_M": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "closed_obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["obligation_id", "q_id", "scope", "weight", "evidence_kind", "evidence_class", "evidence_digest"],
        "properties": {
          "obligation_id": {"type": "string", "minLength": 1},
          "q_id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "enum": ["internal", "external"]},
          "weight": {"type": "integer", "minimum": 1, "maximum": 1000},
          "evidence_kind": {"type": "string", "enum": ["ledger", "corpus"]},
          "evidence_class": {"type": "string", "minLength": 1},
          "evidence_digest": {"type": "string"}
        }
      }
    },
    "open_obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["obligation_id", "q_id", "scope", "weight", "evidence_kind", "evidence_class"],
        "properties": {
          "obligation_id": {"type": "string", "minLength": 1},
          "q_id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "enum": ["internal", "external"]},
          "weight": {"type": "integer", "minimum": 1, "maximum": 1000},
          "evidence_kind": {"type": "string", "enum": ["ledger", "corpus"]},
          "evidence_class": {"type": "string", "minLength": 1}
        }
      }
    },
    "input_ledger_head": {"type": "string", "minLength": 64},
    "output_ledger_head": {"type": "string", "minLength": 64},
    "corpus_snapshot_digest": {"type": "string", "minLength": 64},
    "reproducibility_receipt_digest": {"type": "string", "minLength": 64},
    "scorecard_digest": {"type": "string", "minLength": 64}
  }
}
