{
  "schema": "wuci-production-authority-policy-v1",
  "status": "production-authority-required-before-production-claim-v1",
  "fixture_authority_allowed_for_production": false,
  "required_authority_fields": [
    "schema",
    "suite",
    "production",
    "authority-id",
    "group-public-key",
    "allow-open",
    "allow-release",
    "allow-trust",
    "allow-publish"
  ],
  "required_for_production": {
    "production": true,
    "fixture_path_rejected": true,
    "known_fixture_or_demo_group_key_rejected": true,
    "key_ceremony_document_required": true,
    "key_ceremony_signature_required": true,
    "key_ceremony_signature_namespace": "wuci-production-authority-v1",
    "ceremony_threshold_minimum": 4,
    "ceremony_signer_count_minimum": 5,
    "root_sha256_record_required": true,
    "publish_or_trust_requires_assembly_gate": true
  },
  "golden_lock": {
    "schema": "wuci-golden-lock-v1",
    "normal_open_release_threshold": {
      "n": 5,
      "t": 3
    },
    "root_authority_audit_ceremony_threshold": {
      "n": 5,
      "t": 4
    }
  },
  "non_claims": [
    "fixture FROST is never production authority",
    "production authority does not imply runtime sandboxing",
    "production authority does not imply quantum safety"
  ]
}
