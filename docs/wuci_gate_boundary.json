{
  "schema": "wuci-gate-boundary-v1",
  "status": "python-preview-plus-assembly-flat-contract",
  "enforcement_implemented": true,
  "assembly_command_enforcement_implemented": true,
  "assembly_owned_surfaces": [
    "manifest-file",
    "warrant-message-file",
    "frost-secp256k1-challenge",
    "frost-secp256k1-verify",
    "open-file-keyfile",
    "gate-contract-verify",
    "open-authorized-contract"
  ],
  "python_workflow_surfaces": [
    "tools/wuci_frost_authorize.py",
    "tools/wuci_gate.py",
    "tools/wuci_receipt_contract.py",
    "tests/frost_authorization_workflow.py",
    "tests/wuci_receipt_contract.py",
    "tests/wuci_gate_contract_asm.py",
    "tests/wuci_gate_policy_matrix.py",
    "tests/wuci_gate_workflow.py"
  ],
  "assembly_contract_commands": [
    {
      "name": "gate-contract-verify",
      "shape": "gate-contract-verify <artifact> <contract>",
      "required_action": "open",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "implemented": true
    },
    {
      "name": "open-authorized-contract",
      "shape": "open-authorized-contract <keyfile> <artifact> <contract> <out>",
      "required_action": "open",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "implemented": true
    }
  ],
  "future_commands": [
    {
      "name": "release-authorized-contract",
      "shape": "release-authorized-contract <artifact> <contract>",
      "required_action": "release",
      "implemented": false
    },
    {
      "name": "release-authorized",
      "shape": "release-authorized <artifact> <receipt>",
      "required_action": "release",
      "implemented": false
    }
  ],
  "receipt_policy_inputs": [
    "schema",
    "suite",
    "production",
    "action",
    "authorization_message_schema",
    "authorization_message_sha256",
    "artifact_manifest_sha256",
    "artifact_manifest",
    "group_public_key",
    "group_commitment",
    "challenge",
    "signature_commitment",
    "signature_scalar",
    "verification"
  ],
  "receipt_display_only_fields": [
    "mode",
    "warning"
  ],
  "receipt_private_material_forbidden": [
    "group_secret",
    "share",
    "hiding",
    "binding",
    "hiding_nonce",
    "binding_nonce",
    "signature_share"
  ],
  "expected_rejection_classes": [
    "malformed_receipt",
    "unsupported_schema",
    "unsupported_suite",
    "production_receipt",
    "wrong_action",
    "artifact_manifest_digest_mismatch",
    "artifact_manifest_field_mismatch",
    "authorization_message_digest_mismatch",
    "challenge_mismatch",
    "invalid_signature",
    "private_material",
    "wrong_open_action",
    "wrong_key_after_authorization",
    "output_exists",
    "output_parent_missing",
    "output_parent_not_directory"
  ],
  "non_goals": [
    "Do not add assembly release-authorized-contract yet.",
    "Do not parse receipt JSON in assembly.",
    "Do not accept arbitrary signer material.",
    "Do not accept non-open actions through open-authorized-contract.",
    "Do not make Python the canonical authorization-message owner."
  ]
}
