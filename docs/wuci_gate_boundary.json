{
  "schema": "wuci-gate-boundary-v1",
  "status": "python-preview-plus-assembly-rooted-contracts",
  "enforcement_implemented": true,
  "assembly_command_enforcement_implemented": true,
  "assembly_owned_surfaces": [
    "manifest-file",
    "warrant-message-file",
    "frost-secp256k1-challenge",
    "frost-secp256k1-verify",
    "open-file-keyfile",
    "authority-root-verify",
    "gate-contract-verify",
    "gate-contract-verify-rooted",
    "open-authorized-contract",
    "open-authorized-rooted",
    "release-authorized-contract",
    "release-authorized-rooted"
  ],
  "python_workflow_surfaces": [
    "tools/wuci_frost_authorize.py",
    "tools/wuci_gate.py",
    "tools/wuci_receipt_contract.py",
    "tools/wuci_authority_root.py",
    "tests/frost_authorization_workflow.py",
    "tests/wuci_receipt_contract.py",
    "tests/wuci_gate_contract_asm.py",
    "tests/wuci_gate_rooted_contract_asm.py",
    "tests/wuci_gate_policy_matrix.py",
    "tests/wuci_gate_workflow.py"
  ],
  "authority_root": {
    "schema": "wuci-authority-root-v1",
    "suite": "FROST-secp256k1-SHA256-v1",
    "production": false,
    "authority_id": "sha256(decoded group-public-key)",
    "required_policy": {
      "allow-open": "required true for rooted open commands; may be false for release-only roots",
      "allow-release": "required true for release-authorized-rooted; may be false for open-only roots",
      "allow-trust": false,
      "allow-publish": false
    }
  },
  "assembly_contract_commands": [
    {
      "name": "gate-contract-verify",
      "shape": "gate-contract-verify <artifact> <contract>",
      "required_action": "open",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "implemented": true
    },
    {
      "name": "gate-contract-verify-rooted",
      "shape": "gate-contract-verify-rooted <authority> <artifact> <contract>",
      "required_action": "open",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "authority_schema": "wuci-authority-root-v1",
      "implemented": true
    },
    {
      "name": "open-authorized-contract",
      "shape": "open-authorized-contract <keyfile> <artifact> <contract> <out>",
      "required_action": "open",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "implemented": true
    },
    {
      "name": "open-authorized-rooted",
      "shape": "open-authorized-rooted <authority> <keyfile> <artifact> <contract> <out>",
      "required_action": "open",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "authority_schema": "wuci-authority-root-v1",
      "implemented": true
    },
    {
      "name": "release-authorized-contract",
      "shape": "release-authorized-contract <artifact> <contract>",
      "required_action": "release",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "implemented": true
    },
    {
      "name": "release-authorized-rooted",
      "shape": "release-authorized-rooted <authority> <artifact> <contract>",
      "required_action": "release",
      "contract_schema": "wuci-gate-receipt-contract-v1",
      "authority_schema": "wuci-authority-root-v1",
      "implemented": true
    }
  ],
  "future_commands": [
    {
      "name": "release-authorized",
      "shape": "release-authorized <artifact> <receipt>",
      "required_action": "release",
      "implemented": false
    }
  ],
  "receipt_policy_inputs": [
    "schema",
    "suite",
    "production",
    "action",
    "authorization_message_schema",
    "authorization_message_sha256",
    "artifact_manifest_sha256",
    "artifact_manifest",
    "group_public_key",
    "group_commitment",
    "challenge",
    "signature_commitment",
    "signature_scalar",
    "verification"
  ],
  "receipt_display_only_fields": [
    "mode",
    "warning"
  ],
  "receipt_private_material_forbidden": [
    "group_secret",
    "share",
    "hiding",
    "binding",
    "hiding_nonce",
    "binding_nonce",
    "signature_share"
  ],
  "expected_rejection_classes": [
    "malformed_receipt",
    "unsupported_schema",
    "unsupported_suite",
    "production_receipt",
    "wrong_action",
    "artifact_manifest_digest_mismatch",
    "artifact_manifest_field_mismatch",
    "authorization_message_digest_mismatch",
    "challenge_mismatch",
    "invalid_signature",
    "private_material",
    "malformed_authority_root",
    "unsupported_authority_schema",
    "unsupported_authority_suite",
    "authority_id_mismatch",
    "authority_group_key_mismatch",
    "authority_open_disallowed",
    "authority_release_disallowed",
    "wrong_open_action",
    "wrong_release_action",
    "wrong_rooted_release_action",
    "publish_bundle_tamper",
    "wrong_key_after_authorization",
    "output_exists",
    "output_parent_missing",
    "output_parent_not_directory"
  ],
  "non_goals": [
    "Do not parse release receipt JSON in assembly.",
    "Do not parse receipt JSON in assembly.",
    "Do not accept arbitrary signer material.",
    "Do not accept non-open actions through open-authorized-contract.",
    "Do not accept non-open actions through open-authorized-rooted.",
    "Do not accept non-release actions through release-authorized-contract.",
    "Do not accept non-release actions through release-authorized-rooted.",
    "Do not make Python the canonical authorization-message owner."
  ]
}
