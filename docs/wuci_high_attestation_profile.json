{
  "schema": "wuci-high-attestation-profile-v1",
  "status": "defensive-high-attestation-baseline-v1",
  "updated_utc": "2026-06-27",
  "scope": "local deterministic WUCI proof evidence for build, verifier, witness, ledger, CAGE, QCAGE, HARDEN, and install lanes",
  "adoption_license": "Apache-2.0",
  "government_baseline": [
    {
      "authority": "NIST",
      "reference": "Cybersecurity Framework 2.0",
      "source_url": "https://www.nist.gov/cyberframework",
      "applied_as": "governance, risk framing, supply-chain evidence, and recoverable proof records"
    },
    {
      "authority": "NIST",
      "reference": "SP 800-218 Secure Software Development Framework",
      "source_url": "https://csrc.nist.gov/pubs/sp/800/218/final",
      "applied_as": "secure software development evidence across prepare, protect, produce, and respond practices"
    },
    {
      "authority": "OMB",
      "reference": "M-22-18 software supply chain secure development attestation",
      "source_url": "https://www.whitehouse.gov/wp-content/uploads/2022/09/M-22-18.pdf",
      "applied_as": "self-attestation evidence, SBOM/artifact readiness, and critical-software proof discipline"
    },
    {
      "authority": "NIST",
      "reference": "FIPS 203 ML-KEM, FIPS 204 ML-DSA, and FIPS 205 SLH-DSA",
      "source_url": "https://csrc.nist.gov/projects/post-quantum-cryptography/post-quantum-cryptography-standardization",
      "applied_as": "post-quantum migration targets; classical-only evidence must not claim quantum safety"
    },
    {
      "authority": "NSA",
      "reference": "CNSA 2.0 quantum-resistant algorithm guidance",
      "source_url": "https://media.defense.gov/2022/Sep/07/2003071836/-1/-1/0/CSI_CNSA_2.0_FAQ_.PDF",
      "applied_as": "CRQC migration pressure, long-lived public evidence strength, and no PQ verifier stubs"
    },
    {
      "authority": "CISA",
      "reference": "Secure by Design, Known Exploited Vulnerabilities, and software attestation practice",
      "source_url": "https://www.cisa.gov/securebydesign",
      "applied_as": "defensive defaults, vulnerability-debt discipline, exploit-chain reduction, and evidence-backed release gates"
    }
  ],
  "explicit_non_claims": [
    "runtime sandbox enforcement",
    "network sandbox enforcement outside the CARROT kernel proof lane",
    "post-quantum security from classical-only evidence",
    "production trust from fixture authority",
    "publish or trust authority before assembly-enforced Gate commands exist",
    "absence of exploitable vulnerabilities"
  ],
  "critical_threats": [
    "fake verifier binary manufacturing proof outputs",
    "fixture authority relabeled as production trust",
    "public witness bundle containing private material",
    "public evidence read through symlink or hardlink surprises",
    "ledger rewrite or fork accepted as append-only history",
    "cryptographic downgrade or quantum-safe overclaim",
    "runtime sandbox or no-network overclaim",
    "reserved trust or publish action accepted without assembly Gate enforcement",
    "dependency drift or network fetch during proof execution",
    "known-exploited-vulnerability debt in build and verification dependencies"
  ],
  "required_local_controls": {
    "offline_deterministic_proofs": true,
    "stdlib_only_policy_tests": true,
    "pinned_qemu_cpu_for_x25519": "Haswell-v4",
    "kernel_no_network_sandbox_proof": true,
    "assembly_no_network_probe": true,
    "seccomp_network_syscall_deny_filter": true,
    "rust_sandbox_wrapper_source": true,
    "rust_sandbox_wrapper_build_gate": true,
    "rust_sandbox_wrapper_selftest": true,
    "verifier_identity_recorded": true,
    "unapproved_runner_rejected_in_strict_mode": true,
    "fixture_authority_test_only": true,
    "reserved_actions_denied_by_default": [
      "trust",
      "publish"
    ],
    "public_evidence_rejects_symlink_and_hardlink_surprises": true,
    "ledger_history_verification_required": true,
    "atomic_writes_required_where_practical": true,
    "unsigned_install_manifest_rejected": true,
    "machine_readable_cli_outputs": true,
    "wjstar_formal_composition_model": true,
    "wjnext_canonical_transcript_model": true,
    "deterministic_parser_corpus_replay": true,
    "parser_hardening_proof": true,
    "release_bundle_verifier": true,
    "real_pq_verifier_pins_fail_closed": true,
    "real_pq_external_verifier_protocol": "wuci-pq-external-verify-v1",
    "local_fips204_ml_dsa_verifier_proof": true,
    "signed_production_authority_ceremony_required": true,
    "signed_external_audit_evidence_required": true,
    "external_audit_signature_namespace": "wuci-external-audit-v1",
    "multi_core_proof_execution_supported": true
  },
  "digest_policy": {
    "sha256_required_for_existing_assembly_compatibility": true,
    "sha384_sha512_required_for_long_lived_public_evidence": true,
    "preferred_public_evidence_digest": "sha512",
    "minimum_quantum_collision_digest": "sha384"
  },
  "post_quantum_policy": {
    "quantum_safe_default": false,
    "classical_vulnerable_public_key": [
      "secp256k1",
      "x25519"
    ],
    "real_pq_targets": [
      "ML-KEM",
      "ML-DSA",
      "SLH-DSA"
    ],
    "candidate_tracking": [
      "HQC"
    ],
    "reject_pq_stub_marked_as_real": true,
    "external_verifier_protocol": "wuci-pq-external-verify-v1",
    "local_fips204_ml_dsa_verifier": "tools/wuci-pq-fips204-verify",
    "local_fips204_ml_dsa_verifier_target": "make pq-verifier-fips204-proof",
    "require_pinned_real_pq_verifier_before_quantum_safe_claim": true
  },
  "required_make_targets": [
    "check-qemu-x25519-cpu",
    "carrot-policy",
    "kernel-sandbox-proof",
    "rust-sandbox-build",
    "rust-sandbox-test",
    "sbom-provenance",
    "sbom-provenance-test",
    "pq-verifier-detect",
    "pq-verifier-fips204-proof",
    "pq-verifier-real-attest",
    "pq-verifier-real",
    "pq-verifier-test",
    "production-authority-verify",
    "production-readiness-gates",
    "crypto-self-audit",
    "crypto-self-audit-test",
    "external-audit-test",
    "wjstar-model-test",
    "wjnext-model-test",
    "parser-corpus-replay",
    "parser-corpus-replay-test",
    "parser-hardening-proof",
    "verify-release-bundle",
    "host-capacity",
    "asm-smoke",
    "check-asm-immediates",
    "harden-policy-matrix",
    "cage-policy-matrix",
    "cage-bundle-test",
    "qcage-model-test",
    "qcage-policy-matrix",
    "gate-contract-asm",
    "test-linux"
  ]
}
