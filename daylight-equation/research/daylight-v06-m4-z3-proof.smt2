; Daylight v0.6 M4 predicate proof.
; Expected result: every check-sat query below returns unsat.
; This proves the Boolean predicate model only; it is not external review,
; production authority, runtime containment, or a cryptographic primitive proof.

(set-logic QF_UF)

(declare-fun ParseOK () Bool)
(declare-fun SuiteOK () Bool)
(declare-fun AuxHashOK () Bool)
(declare-fun KEMBlockOK () Bool)
(declare-fun ModeOK () Bool)
(declare-fun PolicyOK () Bool)
(declare-fun ClaimOK () Bool)
(declare-fun GateOK () Bool)
(declare-fun ProvenanceOK () Bool)
(declare-fun ContentReviewPreOK () Bool)
(declare-fun V_Auth () Bool)
(declare-fun NoDowngradeFinal () Bool)
(declare-fun LogOK () Bool)
(declare-fun InstallOK () Bool)
(declare-fun WitnessOK () Bool)

(declare-fun DeriveOK () Bool)
(declare-fun |AEAD.Dec| () Bool)
(declare-fun PayloadOK () Bool)
(declare-fun CommitOK () Bool)
(declare-fun LeakOK () Bool)

(declare-fun AtLeastOneKEMSharedSecretPseudorandom () Bool)
(declare-fun HKDF_SHA512_Extractor_PRF () Bool)
(declare-fun AEAD_IND_CCA () Bool)
(declare-fun PublicKeysValidate () Bool)
(declare-fun SideChannelsBounded () Bool)

(define-fun PublicOK () Bool
  (and ParseOK SuiteOK AuxHashOK KEMBlockOK ModeOK PolicyOK ClaimOK GateOK
       ProvenanceOK ContentReviewPreOK V_Auth NoDowngradeFinal LogOK InstallOK
       WitnessOK))

(define-fun PrivateOK () Bool
  (and DeriveOK |AEAD.Dec| PayloadOK CommitOK LeakOK))

(define-fun OpenSuccess () Bool
  (and PublicOK PrivateOK))

(define-fun PrivateOpsAllowed () Bool
  PublicOK)

(define-fun ConfidentialityAssumptionsOK () Bool
  (and AtLeastOneKEMSharedSecretPseudorandom HKDF_SHA512_Extractor_PRF
       AEAD_IND_CCA PublicKeysValidate SideChannelsBounded))

(define-fun ConfidentialReleaseAllowed () Bool
  (and ConfidentialityAssumptionsOK OpenSuccess))

; Open succeeds if and only if every public and private predicate holds.
(push)
(assert (not (= OpenSuccess (and PublicOK PrivateOK))))
(check-sat)
(pop)

; A failed public precheck blocks private operations.
(push)
(assert (and (not PublicOK) PrivateOpsAllowed))
(check-sat)
(pop)

; Open cannot succeed without private operations being allowed.
(push)
(assert (and OpenSuccess (not PrivateOpsAllowed)))
(check-sat)
(pop)

; Every single predicate failure forces Open = bottom.
(push)
(assert (and OpenSuccess (not ParseOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not SuiteOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not AuxHashOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not KEMBlockOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ModeOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not PolicyOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ClaimOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not GateOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ProvenanceOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ContentReviewPreOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not V_Auth)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not NoDowngradeFinal)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not LogOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not InstallOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not WitnessOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not DeriveOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not |AEAD.Dec|)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not PayloadOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not CommitOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not LeakOK)))
(check-sat)
(pop)

; Authorization predicates are necessary for Open.
(push)
(assert (and OpenSuccess (not V_Auth)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not GateOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not PolicyOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ClaimOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ContentReviewPreOK)))
(check-sat)
(pop)

; Downgrade predicates are necessary for Open.
(push)
(assert (and OpenSuccess (not NoDowngradeFinal)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ModeOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not PolicyOK)))
(check-sat)
(pop)
(push)
(assert (and OpenSuccess (not ClaimOK)))
(check-sat)
(pop)

; Confidential release is conditional on all modeled assumptions.
(push)
(assert (and ConfidentialReleaseAllowed
             (not AtLeastOneKEMSharedSecretPseudorandom)))
(check-sat)
(pop)
(push)
(assert (and ConfidentialReleaseAllowed
             (not HKDF_SHA512_Extractor_PRF)))
(check-sat)
(pop)
(push)
(assert (and ConfidentialReleaseAllowed
             (not AEAD_IND_CCA)))
(check-sat)
(pop)
(push)
(assert (and ConfidentialReleaseAllowed
             (not PublicKeysValidate)))
(check-sat)
(pop)
(push)
(assert (and ConfidentialReleaseAllowed
             (not SideChannelsBounded)))
(check-sat)
(pop)
(push)
(assert (and ConfidentialReleaseAllowed (not OpenSuccess)))
(check-sat)
(pop)
